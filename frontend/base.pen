                      "fill": "#1F2937",
                      "content": "Visión",
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "frame",
                      "id": "dV78e",
                      "name": "desc2",
                      "width": "fill_container",
                      "layout": "vertical",
                      "children": [
                        {
                          "type": "text",
                          "id": "RrLxi",
                          "name": "desc2txt",
                          "fill": "#6B7280",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Convertirnos en la referencia principal de educación accesible en el sureste mexicano, impulsando una cultura de aprendizaje continuo y democratizando el conocimiento sin importar la condición económica o ubicación geográfica.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "dxqKe",
